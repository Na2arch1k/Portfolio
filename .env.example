# Resend (https://resend.com) — required in production.
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional. Sender address for both emails. Must be on a domain verified
# in Resend (https://resend.com/domains). Defaults to onboarding@resend.dev,
# which only delivers to the email of your own Resend account — set this
# to e.g. "Назарій Гарасимчук <hello@nazariidev.com>" before going live
# so visitors receive the auto-reply.
CONTACT_FROM_EMAIL=

# Optional. Where contact-form leads are delivered.
# Defaults to the email in src/lib/constants.ts.
CONTACT_TO_EMAIL=

# Optional. Sends an instant Telegram notification for every submission,
# in addition to email. Both must be set for it to activate; leaving
# either blank silently skips this step.
#
# TELEGRAM_BOT_TOKEN: message @BotFather on Telegram, send /newbot,
# follow the prompts — it replies with a token like 123456:ABC-DEF...
#
# TELEGRAM_CHAT_ID: message your new bot once (anything, e.g. /start),
# then open https://api.telegram.org/bot<TOKEN>/getUpdates in a browser
# and copy the "id" under "chat". (Or message @userinfobot to get your
# own numeric Telegram ID directly.)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional. Google Analytics 4 Measurement ID (looks like G-XXXXXXXXXX).
# Get it from analytics.google.com → Admin → Data Streams → your web
# stream. Leaving this blank simply skips loading GA entirely.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
